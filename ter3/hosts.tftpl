[webservers]
%{ for vm in web_instances ~}
${vm.name} ansible_host=${vm.ip} fqdn=${vm.fqdn}
%{ endfor ~}

[databases]
%{ for vm in db_instances ~}
${vm.name} ansible_host=${vm.ip} fqdn=${vm.fqdn}
%{ endfor ~}

[storage]
${storage_instance.name} ansible_host=${storage_instance.ip} fqdn=${storage_instance.fqdn}
